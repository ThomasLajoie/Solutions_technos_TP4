# =========================
# ROOT / GENERAL
# =========================

.DS_Store
Thumbs.db
erl_crash.dump

# Environment files
.env
.env.*
!.env.example
!.env.test

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# FRONTENDS (Svelte / Node / Vite)
# Covers:
# - MVP/*frontend
# - POC/*frontend
# - Prototype/*frontend
# =========================

MVP/*frontend/node_modules/
MVP/*frontend/.svelte-kit/
MVP/*frontend/build/
MVP/*frontend/dist/
MVP/*frontend/.output/
MVP/*frontend/.vercel/
MVP/*frontend/.netlify/
MVP/*frontend/.wrangler/
MVP/*frontend/.vite/

POC/*frontend/node_modules/
POC/*frontend/.svelte-kit/
POC/*frontend/build/
POC/*frontend/dist/
POC/*frontend/.output/
POC/*frontend/.vercel/
POC/*frontend/.netlify/
POC/*frontend/.wrangler/
POC/*frontend/.vite/

Prototype/*frontend/node_modules/
Prototype/*frontend/.svelte-kit/
Prototype/*frontend/build/
Prototype/*frontend/dist/
Prototype/*frontend/.output/
Prototype/*frontend/.vercel/
Prototype/*frontend/.netlify/
Prototype/*frontend/.wrangler/
Prototype/*frontend/.vite/

# Vite timestamp/cache files
MVP/*frontend/vite.config.js.timestamp-*
MVP/*frontend/vite.config.ts.timestamp-*
POC/*frontend/vite.config.js.timestamp-*
POC/*frontend/vite.config.ts.timestamp-*
Prototype/*frontend/vite.config.js.timestamp-*
Prototype/*frontend/vite.config.ts.timestamp-*

# =========================
# BACKENDS (Phoenix / Elixir)
# Covers:
# - MVP/*backend
# - POC/*backend
# - Prototype/*backend
# =========================

MVP/*backend/_build/
MVP/*backend/deps/
MVP/*backend/cover/
MVP/*backend/.elixir_ls/
MVP/*backend/priv/static/assets/
MVP/*backend/priv/static/cache_manifest.json
MVP/*backend/priv/static/uploads/

POC/*backend/_build/
POC/*backend/deps/
POC/*backend/cover/
POC/*backend/.elixir_ls/
POC/*backend/priv/static/assets/
POC/*backend/priv/static/cache_manifest.json
POC/*backend/priv/static/uploads/

Prototype/*backend/_build/
Prototype/*backend/deps/
Prototype/*backend/cover/
Prototype/*backend/.elixir_ls/
Prototype/*backend/priv/static/assets/
Prototype/*backend/priv/static/cache_manifest.json
Prototype/*backend/priv/static/uploads/

# =========================
# OPTIONAL: archives / temp files
# =========================

*.tmp
*.temp